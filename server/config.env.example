# MetArt Backend Configuration Template
# Copy this file to 'config.env' in this directory and fill in your actual credentials.

# Server Port
PORT=8000

# Client App URL (CORS setting)
CLIENT_URL=http://localhost:3000

# MongoDB Connection String (Local development default)
DATABASE_URI=mongodb://127.0.0.1:27017/metart

# JWT Token Secret Key (Change this to a long random string in production)
JWT_SECRET_KEY=your_jwt_secret_key_here

# Cloudinary Credentials (For image uploads and anti-piracy watermarking)
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe Credentials (For credit card payment checkout flows)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Email Credentials (For nodemailer verification and user updates)
EMAIL_ADDRESS=your_email@example.com
APP_PASSWORD=your_email_app_password
